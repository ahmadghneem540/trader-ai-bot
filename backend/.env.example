# Application
APP_NAME=TraderAI
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0

# Server
HOST=0.0.0.0
PORT=8000

# Database
POSTGRES_USER=traderai
POSTGRES_PASSWORD=traderai_secret_password
POSTGRES_DB=traderai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://traderai:traderai_secret_password@localhost:5432/traderai

# MetaTrader 5
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=FxPro-Demo
MT5_PATH=

# MetaApi Cloud
META_API_TOKEN=your_meta_api_token
META_API_ACCOUNT_ID=your_meta_api_account_id

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log

# Security
SECRET_KEY=your_very_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
